{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
		"my-lib": {
            "projectType": "library",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "projects/my-lib",
            "sourceRoot": "projects/my-lib/src",
            "prefix": "lib",
            "architect": {
                "build": {
                "builder": "@angular-devkit/build-angular:ng-packagr",
                "options": {
                    "project": "projects/my-lib/ng-package.json"
                },
                "configurations": {
                    "prod": {
                        "tsConfig": "projects/my-lib/tsconfig.lib.prod.json"
                    },
                    "devtest": {
                        "tsConfig": "projects/my-lib/tsconfig.lib.json"
                    }
                },
                "defaultConfiguration": "prod"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "projects/my-lib/src/test.ts",
                        "tsConfig": "projects/my-lib/tsconfig.spec.json",
                        "karmaConfig": "projects/my-lib/karma.conf.js"
                    }
                }
            }
        },
		"core": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "projects/core",
            "sourceRoot": "projects/core/src",
            "prefix": "app",
            "architect": {
                "build": {
                "builder": "@angular-devkit/build-angular:browser",
                "options": {
                    "outputPath": "dist/core",
                    "index": "projects/core/src/index.html",
                    "main": "projects/core/src/main.ts",
                    "polyfills": "projects/core/src/polyfills.ts",
                    "tsConfig": "projects/core/tsconfig.app.json",
                    "assets": [
                        "projects/core/src/favicon.ico",
                        "projects/core/src/assets",
                        {
                            "glob": "**/*",
                            "input": "projects/shared/assets",
                            "output": "shared/assets"
                        }
                    ],
                    "styles": [
                        "projects/core/src/styles.scss",
                        "node_modules/ngx-spinner/animations/ball-spin-clockwise.css"
                    ],
                    "scripts": [
                        "node_modules/prismjs/prism.js",
                        "node_modules/prismjs/components/prism-typescript.js"
                    ]
                },
                "configurations": {
                    "prod": {
                        "budgets": [
                            {
                                "type": "initial",
                                "maximumWarning": "3mb",
                                "maximumError": "5mb"
                            },
                            {
                                "type": "anyComponentStyle",
                                "maximumWarning": "3mb",
                                "maximumError": "5mb"
                            }
                        ],
                        "fileReplacements": [
                            {
                                "replace": "projects/shared/environments/environment.ts",
                                "with": "projects/shared/environments/environment.prod.ts"
                            }
                        ],
                        "outputHashing": "all"
                    },
                    "stag": {
                        "budgets": [
                            {
                                "type": "initial",
                                "maximumWarning": "3mb",
                                "maximumError": "5mb"
                            },
                            {
                                "type": "anyComponentStyle",
                                "maximumWarning": "3mb",
                                "maximumError": "5mb"
                            }
                        ],
                        "fileReplacements": [
                            {
                                "replace": "projects/shared/environments/environment.ts",
                                "with": "projects/shared/environments/environment.stag.ts"
                            }
                        ],
                        "outputHashing": "all"
                    },
                    "devtest": {
                        "budgets": [
                            {
                                "type": "initial",
                                "maximumWarning": "3mb",
                                "maximumError": "5mb"
                            },
                            {
                                "type": "anyComponentStyle",
                                "maximumWarning": "3mb",
                                "maximumError": "5mb"
                            }
                        ],
                        "fileReplacements": [
                            {
                                "replace": "projects/shared/environments/environment.ts",
                                "with": "projects/shared/environments/environment.dev.ts"
                            }
                        ],
                        "outputHashing": "all"
                    },
                    "development": {
                        "buildOptimizer": false,
                        "optimization": false,
                        "vendorChunk": true,
                        "extractLicenses": false,
                        "sourceMap": true,
                        "namedChunks": true
                    }
                },
                "defaultConfiguration": "prod"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "options": {
                        "browserTarget": "core:build"
                    },
                    "configurations": {
                        "production": {
                            "browserTarget": "core:build:production"
                        },
                        "development": {
                            "browserTarget": "core:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n",
                    "options": {
                        "browserTarget": "core:build"
                    }
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "projects/core/src/test.ts",
                        "polyfills": "projects/core/src/polyfills.ts",
                        "tsConfig": "projects/core/tsconfig.spec.json",
                        "karmaConfig": "projects/core/karma.conf.js",
                        "assets": [
                            "projects/core/src/favicon.ico",
                            "projects/core/src/assets"
                        ],
                        "styles": [
                            "projects/core/src/styles.scss"
                        ],
                        "scripts": []
                    }
                },
                "lint": {
                    "builder": "@angular-devkit/build-angular:tslint",
                    "options": {
                        "tsConfig": [
                            "projects/core/tsconfig.app.json",
                            "projects/core/tsconfig.spec.json"
                        ],
                        "exclude": [
                            "**/node_modules/**"
                        ]
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": "642862f5-e7b4-4d74-8e02-29362cf4113a",
		"schematicCollections": [
			"@schematics/angular"
		]
    }
}
